# Godot 4+ specific
.godot/

# Godot 3.x specific
.import/

# Exported binaries
export/
build/
bin/

# Local editor settings (optional)
# Some prefer to keep these, others ignore them to avoid personal setting conflicts
.vscode/
.idea/
*.swp

# Sensitive credentials (especially for Android exports)
export_credentials.cfg

# Local test runner binary
godot_bin

# 联机双进程集成测试临时目录
.tmp_ittest/
.tmp_ittest_avatar/
.tmp_apdata_srv/
.tmp_apdata_cli/

# ===== 临时 / 无关文件：仅本地保留，不入库 =====
# 根目录随手脚本与日志
_*.py
_*.bat
*_tmp.py
probe_*.txt
core_test_log.txt
test_log.txt
test_out3.log
*.log
*.tmp
*.TMP
project.godot~*
gdscript_codemap.json

# Python 缓存
__pycache__/

# 临时 / 无关文件夹
tmp/
tests/tmp/

# 生成式报告日志（保留 reports/report_*/ 下的 HTML 测试报告）
reports/*.log
reports/*.txt
reports/*.xml

# 运行时 / 沙箱用户数据（Godot 重定向 APPDATA/LOCALAPPDATA 产生的垃圾，可重新生成）
.godata/
.godot_headless/
.sandbox_appdata/
.sandbox_home/
Godot/
