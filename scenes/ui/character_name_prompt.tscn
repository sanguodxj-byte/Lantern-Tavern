[node name="Suffix" type="Label" parent="LetterPanel/Margin/VBox/NameRow"]
layout_mode = 2
size_flags_horizontal = 3
text = ",\nplease confirm by mark and claim the tavern."
autowrap_mode = 3

[node name="ErrorLabel" type="Label" parent="LetterPanel/Margin/VBox" unique_name_in_owner=true]
