[node name="Title" type="Label" parent="LetterPanel/Margin/VBox"]
layout_mode = 2
text = "Inheritance Letter"

[node name="Body" type="RichTextLabel" parent="LetterPanel/Margin/VBox"]
layout_mode = 2
size_flags_vertical = 3
bbcode_enabled = true
fit_content = false
text = "To the new keeper of this tavern,\n\nThe former heir has been struck from this record.\nAll rights, debts, barrels, and broken chairs now pass to you.\n\nDear"

[node name="NameRow" type="HBoxContainer" parent="LetterPanel/Margin/VBox"]
layout_mode = 2

[node name="NameEdit" type="LineEdit" parent="LetterPanel/Margin/VBox/NameRow" unique_name_in_owner=true]
layout_mode = 2
size_flags_horizontal = 3
